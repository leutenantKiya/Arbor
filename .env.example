# --- Database (Neon Postgres, via Vercel Marketplace integration) ---
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Session signing (generate: openssl rand -base64 32) ---
AUTH_SECRET=""

# --- Particle Network (dashboard.particle.network) ---
NEXT_PUBLIC_PARTICLE_PROJECT_ID=""
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=""
NEXT_PUBLIC_PARTICLE_APP_ID=""
# Project Settings > Server Key — server-only, never NEXT_PUBLIC.
# Used to verify {uuid, token} via Particle's getUserInfo RPC (ARCHITECTURE.md §8).
PARTICLE_SERVER_KEY=""

# --- Chain ---
# arbitrum-sepolia (testnet demo) | arbitrum (mainnet, Universal Accounts)
NEXT_PUBLIC_CHAIN="arbitrum-sepolia"
NEXT_PUBLIC_ARBORVAULT_ADDRESS=""
NEXT_PUBLIC_USDC_ADDRESS=""

# --- Settlement signer (server-only; testnet funds only; never NEXT_PUBLIC) ---
SETTLEMENT_PRIVATE_KEY=""
